ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Supabase auth + server-side metadata updates
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional: Stripe billing
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Free LLM providers (no credit card needed)
# Groq: https://console.groq.com — 14,400 req/day free, fastest inference
GROQ_API_KEY=your_groq_api_key_here
# Groq model (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter free models (50 req/day — use as secondary fallback)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OpenRouter free model (default: nvidia/nemotron-3-super-120b-a12b:free)
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# ElevenLabs TTS — https://elevenlabs.io/api
ELEVENLABS_API_KEY=your_elevenlabs_api_key
# Voices: comma-separated "voiceId:Label" pairs. First = default.
# Browse and find voice IDs at: https://elevenlabs.io/voice-library
# Known spiritual voices: "21m00Tcm4TlvDq8ikWAM:Rachel" (default ElevenLabs voice)
# For premium voices (AImee, Jameson, Scottish Grandfather) — find your own IDs:
#   1. Go to https://elevenlabs.io/voice-library
#   2. Find a voice you like, click it, copy the ID from the URL
#   3. Add it here as "ID:Display Name"
NEXT_PUBLIC_ELEVENLABS_VOICES="21m00Tcm4TlvDq8ikWAM:Rachel,EXTERNAL_ID:Soulful,EXTERNAL_ID:Scottish Grandfather"

# Resend — email for weekly digests + notifications
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=dreams@dreamscape.quest

# Cron secret (Vercel cron authorization)
CRON_SECRET=your_cron_secret_here
