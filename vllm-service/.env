# Environment variables for qr-sampler stack
# Engine: vLLM (NVIDIA GPU)
# Model: google/gemma-4-26b-moe
# Entropy source: Quantum gRPC

# Inference engine settings
MODEL=google/gemma-4-26b-moe
INFERENCE_PORT=8000
DTYPE=half
MAX_MODEL_LEN=8192
GPU_MEMORY_UTILIZATION=0.8
HF_TOKEN=

# Entropy source settings
ENTROPY_SERVER_PORT=50051
ENTROPY_SERVER=simple_urandom_server.py
QR_GRPC_SERVER_ADDRESS=entropy-server:50051
QR_SAMPLE_COUNT=20480
QR_GRPC_MODE=unary

# Open WebUI
WEBUI_PORT=3000
OPENAI_API_KEY=dummy
