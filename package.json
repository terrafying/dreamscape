{
  "name": "dreamscape",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:mobile": "NEXT_OUTPUT=export next build && npx cap sync",
    "ios:certs": "cd ios && fastlane certs",
    "ios:certs:dev": "cd ios && fastlane certs_dev",
    "ios:beta": "npm run build:mobile && cd ios && fastlane beta",
    "ios:release": "npm run build:mobile && cd ios && fastlane release",
    "ios:bump": "cd ios && fastlane bump_version type:patch",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "vitest run && playwright test",
    "stripe:webhook:listen": "bash scripts/stripe-local.sh listen",
    "stripe:webhook:trigger:checkout": "bash scripts/stripe-local.sh trigger-checkout",
    "stripe:webhook:trigger:sub-updated": "bash scripts/stripe-local.sh trigger-sub-updated",
    "stripe:webhook:trigger:sub-deleted": "bash scripts/stripe-local.sh trigger-sub-deleted",
    "screenshots": "playwright test tests/e2e/screenshots.spec.ts --project=desktop-screenshots && playwright test tests/e2e/screenshots.spec.ts --project=mobile-screenshots",
    "videos": "playwright test tests/e2e/demo-videos.spec.ts --project=video-iphone",
    "videos:trim": "bash scripts/trim-videos.sh",
    "videos:all": "npm run videos && npm run videos:trim"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@anthropic-ai/sdk": "^0.27.3",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^2.19.1",
    "@remotion/cli": "^4.0.441",
    "@remotion/player": "^4.0.441",
    "@supabase/supabase-js": "^2.99.3",
    "@types/howler": "^2.2.12",
    "@types/three": "^0.164.0",
    "@vercel/analytics": "^1.6.1",
    "ai": "^6.0.116",
    "howler": "^2.2.4",
    "hyperspace.js": "^0.1.0",
    "next": "14.2.5",
    "postprocessing": "^6.36.3",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^2.12.7",
    "remotion": "^4.0.441",
    "resend": "^6.9.4",
    "three": "^0.164.0",
    "tone": "^15.1.22",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@playwright/test": "^1.48.0",
    "@remotion/eslint-plugin": "^4.0.441",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.0.1",
    "jsdom": "^25.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^1.6.0"
  }
}
