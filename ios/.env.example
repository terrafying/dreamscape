# ─────────────────────────────────────────────────────────────────
# Dreamscape iOS — Fastlane Environment Variables
# Copy to ios/.env and fill in your values.
# NEVER commit ios/.env to git.
# ─────────────────────────────────────────────────────────────────

# ── Apple Developer Account ──────────────────────────────────────

# Your Apple ID email (used for App Store Connect login)
FASTLANE_USER=your@email.com

# Apple Developer Team ID
# Find at: https://developer.apple.com → Account → Membership → Team ID
FASTLANE_TEAM_ID=XXXXXXXXXX

# App Store Connect Team ID (often same as FASTLANE_TEAM_ID)
# Find at: https://appstoreconnect.apple.com → Users and Access → Team ID
APP_STORE_CONNECT_TEAM_ID=XXXXXXXXXX

# Apple ID password — use an app-specific password for CI/automation
# Generate at: https://appleid.apple.com/account/manage → App-Specific Passwords
FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Match (Code Signing) ─────────────────────────────────────────

# Private git repo URL where Match stores certificates & profiles
# Create a private repo at github.com, then set this to its SSH or HTTPS URL
MATCH_GIT_URL=git@github.com:your-org/dreamscape-certs.git

# Passphrase to encrypt/decrypt the certificates in the Match repo
# Use a strong random string — store in your password manager
MATCH_PASSWORD=your-strong-passphrase-here

# ── App Store Connect API Key (recommended for CI) ───────────────
# More reliable than password auth; avoids 2FA prompts.
# Generate at: https://appstoreconnect.apple.com → Users and Access → Keys
#
# APP_STORE_CONNECT_API_KEY_KEY_ID=XXXXXXXXXX
# APP_STORE_CONNECT_API_KEY_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# APP_STORE_CONNECT_API_KEY_KEY_FILEPATH=~/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8

# ── Optional ─────────────────────────────────────────────────────

# Release notes shown to TestFlight testers
# BETA_CHANGELOG=Fixed bugs, improved performance
